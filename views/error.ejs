<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .error-container {
      max-width: 600px;
      margin: 100px auto;
      padding: 40px;
      text-align: center;
    }
    .error-container h1 {
      color: #dc3545;
      margin-bottom: 20px;
    }
    .error-container p {
      color: #6c757d;
      margin-bottom: 30px;
    }
    .error-container a {
      color: #0d6efd;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="error-container">
      <h1>Error</h1>
      <p><%= error %></p>
      <a href="/login">Volver al inicio de sesión</a>
    </div>
  </div>
</body>
</html>