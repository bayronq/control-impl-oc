# Aplicación
PORT=3000
NODE_ENV=production
SESSION_SECRET=change_this_to_a_random_secret_key

# Base de datos PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=instalaciones
DB_USER=admin
DB_PASSWORD=your_secure_password_here
DB_SSL=false

# PostgreSQL
POSTGRES_DB=instalaciones
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password_here

# LDAP (Autenticación de dominio)
ENABLE_DOMAIN_LOGIN=false
LDAP_URL=ldap://dc.tu.dominio:389
LDAP_BASE_DN=dc=tu,dc=dominio
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# ServiceNow
SERVICENOW_URL=https://urlmesadeservicio/ui/changes

# Logging
LOG_DIR=/var/logs

# Volúmenes (para persistencia de datos)
VOL_DIR=/work/volumes/contro-imp-oc-data
